# App
# CORS_ORIGINS=*

# AWS (Bedrock) — use IAM role in AWS; or keys locally
AWS_REGION=us-east-1
# Optional Bedrock API key path (SDK bearer token)
# AWS_BEDROCK_API=
# AWS_BEARER_TOKEN_BEDROCK=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20240620-v1:0

# Google AI (diagram vision)
# GEMINI_API_KEY=
GEMINI_VISION_MODEL=gemini-2.0-flash

# Infracost (optional; CLI also reads INFRACOST_API_KEY from env)
# INFRACOST_API_KEY=
